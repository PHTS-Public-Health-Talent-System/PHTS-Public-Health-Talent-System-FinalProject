DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=phts_system
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
DEMO_DISABLE_TOKEN_EXPIRY=false
DEMO_DISABLE_RATE_LIMIT=false
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Email notifications (disabled by default)
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=25
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=

# OCR (Typhoon OCR, disabled by default)
OCR_ENABLED=false
OCR_PROVIDER=TYPHOON
OCR_SERVICE_URL=http://ocr-typhoon:8000
OCR_HTTP_TIMEOUT_MS=900000
OCR_FILE_TIMEOUT_MS=120000
OCR_FILE_RETRY_COUNT=2

# Backup automation (disabled by default)
BACKUP_ENABLED=false
BACKUP_COMMAND=/usr/bin/bash
BACKUP_ARGS=["src/scripts/jobs/backup.sh"]
BACKUP_WORKDIR=/absolute/path/to/phts-project/backend
BACKUP_TIMEOUT_MS=300000
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
