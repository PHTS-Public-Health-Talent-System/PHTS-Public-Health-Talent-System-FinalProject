# Local development profile (minimal, practical defaults)

NODE_ENV=development
PORT=3001
APP_TIMEZONE=Asia/Bangkok
TZ=Asia/Bangkok

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=phts_system
DB_TIMEZONE=+07:00
DB_CONNECT_TIMEOUT_MS=10000

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=replace-with-very-long-random-secret-key-32chars-min
JWT_EXPIRES_IN=7d

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5

DEMO_DISABLE_TOKEN_EXPIRY=false
DEMO_DISABLE_RATE_LIMIT=false

SYNC_WORKER_ENABLED=true
SYNC_WORKER_POLL_MS=30000
SYNC_AUTO_MODE=DAILY
SYNC_AUTO_DAILY_HOUR=2
SYNC_AUTO_DAILY_MINUTE=0
SYNC_AUTO_TIMEZONE=Asia/Bangkok

SNAPSHOT_WORKER_ENABLED=true
SNAPSHOT_WORKER_POLL_MS=10000
SNAPSHOT_WORKER_BATCH_LIMIT=50

NOTIFICATION_OUTBOX_WORKER_ENABLED=true
NOTIFICATION_OUTBOX_WORKER_POLL_MS=10000
NOTIFICATION_OUTBOX_WORKER_BATCH_LIMIT=50

OCR_ENABLED=false
OCR_PROVIDER=TYPHOON
OCR_SERVICE_URL=http://ocr-typhoon:8000
OCR_TESSERACT_LANG=tha+eng
OCR_TESSERACT_OEM=1
OCR_TESSERACT_PSM=11
OCR_TESSERACT_PDF_DPI=200
OCR_TESSERACT_THREAD_LIMIT=1
OCR_TESSERACT_PREPROCESS=none
OCR_TESSERACT_THRESHOLDING_METHOD=
OCR_TESSERACT_THRESHOLDING_WINDOW_SIZE=
OCR_TESSERACT_THRESHOLDING_KFACTOR=
OCR_PADDLE_SERVICE_URL=
OCR_PADDLE_LOCAL_ENABLED=true
OCR_PADDLE_PYTHON_BIN=python3
OCR_PADDLE_LANG=th
OCR_PADDLE_USE_TEXTLINE_ORIENTATION=false
OCR_PADDLE_TEXT_DET_LIMIT_SIDE_LEN=2048
OCR_PADDLE_TEXT_DET_THRESH=0.25
OCR_PADDLE_TEXT_DET_BOX_THRESH=0.45
OCR_PADDLE_TEXT_DET_UNCLIP_RATIO=1.8
OCR_PADDLE_TEXT_REC_SCORE_THRESH=0
OCR_PADDLE_PDF_DPI=300
OCR_PADDLE_DISABLE_MODEL_SOURCE_CHECK=true
OCR_TYPHOON_SERVICE_URL=
OCR_FILE_TIMEOUT_MS=120000
OCR_FILE_RETRY_COUNT=2
OCR_WORKER_ENABLED=true

BACKUP_ENABLED=false
BACKUP_COMMAND=/usr/bin/bash
BACKUP_ARGS=["src/scripts/ops/backup/backup.sh"]
BACKUP_WORKDIR=/absolute/path/to/phts-project/backend
BACKUP_TIMEOUT_MS=300000
BACKUP_WORKER_ENABLED=true
BACKUP_WORKER_POLL_MS=60000
BACKUP_JOB_TIMEZONE=Asia/Bangkok
