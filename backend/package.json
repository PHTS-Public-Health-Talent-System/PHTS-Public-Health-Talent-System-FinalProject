{
  "name": "phts-backend",
  "version": "1.0.0",
  "description": "PHTS (Public Health Talent System) - Backend API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "TZ=Asia/Bangkok tsx watch src/index.ts",
    "build": "tsc",
    "start": "TZ=Asia/Bangkok node dist/index.js",
    "sync:all": "TZ=Asia/Bangkok tsx src/scripts/jobs/sync_service.ts",
    "assign:roles": "TZ=Asia/Bangkok tsx src/scripts/admin/assign_roles.ts",
    "db:setup": "TZ=Asia/Bangkok tsx src/scripts/db/setup.ts",
    "admin:create": "TZ=Asia/Bangkok tsx src/scripts/admin/create_admin.ts",
    "jobs:run": "TZ=Asia/Bangkok tsx src/scripts/jobs/scheduled_jobs.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "test": "jest",
    "test:perf": "RUN_PERF=1 jest src/__tests__/perf",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "hospital",
    "hrms",
    "pts",
    "healthcare",
    "thailand"
  ],
  "author": "PHTS Development Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.3.1",
    "esbuild": "^0.27.2",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "file-type": "^21.3.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "mysql2": "^3.6.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.15.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "archiver": "^7.0.1",
    "archiver-utils": "^5.0.2",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.5",
    "@types/passport": "^1.0.16",
    "@types/passport-jwt": "^4.0.0",
    "@types/pdfkit": "^0.13.6",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "baseline-browser-mapping": "^2.9.15",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
